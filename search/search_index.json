p> <p>A\uff1a\u56e0\u4e3a\u6570\u5b66\u5b66\u592a\u70c2\u4e86...\u5176\u5b9e\u4e5f\u6709\u4e00\u4e9b\u4e0a\u8bfe\u8bb0\u7684\u7b14\u8bb0\uff0c\u4f46\u662f\u592a\u591a\u592a\u6742\u4e86\uff0c\u6574\u7406\u51fa\u6765\u4e5f\u8981\u8d39\u4e0d\u5c11\u529f\u592b</p>"}, {"location": "notes/isee/ec/", "title": "\u7535\u5b50\u7535\u8def\u57fa\u7840", "text": "<p>Instructor\uff1a\u5c48\u4e07\u56ed\u3001\u5f20\u8fd0\u708e</p> <p>Semaster\uff1a\u5927\u4e8c\u79cb\u51ac</p> <p>\u8bfe\u7a0b\u7c7b\u522b\uff1a\u4e13\u4e1a\u5fc5\u4fee</p> <p>\u63a8\u8350\u6307\u6570\uff1a\uff08\u4f46\u662f\u662f\u6574\u4e2a\u5b66\u9662\u5fc5\u4fee\uff0c\u4e0d\u60f3\u4fee\u4e5f\u6ca1\u529e\u6cd5\uff09</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ec/#_1", "title": "\u8bfe\u7a0b\u6982\u8ff0", "text": "", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ec/#_2", "title": "\u5173\u4e8e\u8bfe\u7a0b", "text": "<ul> <li>\u4fe1\u7535\u56db\u5927\u5929\u4e66\u4e4b\u4e00</li> <li>\u5c0f\u65f6\u5019\u77e5\u9053\u4ee5\u540e\u8981\u5b66\u6a21\u7535\u5413\u54ed\u4e86</li> <li>\u50ac\u751f\u79cd\u79cd\u77e5\u540did\u201c\u5b66\u4e0d\u6765\u6a21\u7535\u201d\u3001\u201c\u4e0d\u5b66\u7535\u57fa\u201d...</li> </ul> <p>\u8bfe\u7a0b\u6574\u4f53\u6db5\u76d6\u7535\u8def\u539f\u7406\u4e0e\u6a21\u62df\u7535\u8def\u4e24\u4e2a\u90e8\u5206\uff1b\u7535\u8def\u539f\u7406\u90e8\u5206\u76f8\u5bf9\u7b80\u5355\uff0c\u4e3b\u8981\u662f\u57fa\u5c14\u970d\u592b\u5b9a\u5f8b\u3001\u7b49\u6548\u7535\u8def\u5b9a\u5f8b\u4ee5\u53caRC\u7535\u8def\u77ac\u6001\u54cd\u5e94\u5206\u6790\u7b49\u5185\u5bb9\uff0c\u7ed3\u5408\u7535\u8bbe\u5b9e\u9a8cI\u98df\u7528\u4f1a\u8f83\u597d\u7406\u89e3\uff1b</p> <p>\u6a21\u7535\u90e8\u5206\u5c31\u5f00\u59cb\u5929\u4e66\u4e86\uff0cBJT\u4e0eFET\u7684\u5c0f\u4fe1\u53f7\u5206\u6790\u3001\u53cd\u9988\u3001\u9891\u7387\u54cd\u5e94\u3001\u529f\u653e\u7b49\uff0c\u4ed9\u4e4b\u4eba\u516e\u5217\u5982\u9ebb...\u6211\u4eec\u867d\u7136\u6982\u5ff5\u4e0a\u4e0d\u597d\u7406\u89e3\uff0c\u4f46\u662f\u4e5f\u4e0d\u597d\u8ba1\u7b97\u554a\uff08\u7279\u522b\u662f24\u7ea7\u7684\u8003\u8bd5\uff0c\u8fd9\u9898\u592a\u591a\u4e86\uff0c\u8ba1\u7b97\u5668\u90fd\u6765\u4e0d\u53ca\u6441.jpg\uff09\u4f46\u662f\u6a21\u7535\u53c8\u6bd4\u8f83\u91cd\u8981\uff0c\u5efa\u8bae\u591a\u82b1\u4e00\u4e9b\u65f6\u95f4\u5b66\uff0c\u867d\u7136\u8fd9\u6837\u4e0d\u4e00\u5b9a\u80fd\u8ba9\u4f60\u62ff\u5230\u6bd4\u8f83\u597d\u7684\u6210\u7ee9\uff0c\u4f46\u5bf9\u4e8e\u4e4b\u540e\u7684\u7535\u8def\u8bfe\u8fd8\u662f\u6709\u4e00\u4e9b\u5e2e\u52a9\u7684\u3002</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ec/#_3", "title": "\u5173\u4e8e\u8001\u5e08", "text": "<p>\u5c48\u4e07\u56ed\u8001\u5e08\u4e0a\u8bfe\u6bd4\u8f83\u6e05\u6670\u6709\u903b\u8f91\uff0c\u6574\u4f53\u4e0a\u6bd4\u8f83\u5feb\u4f46\u662f\u4f1a\u7ed9\u540c\u5b66\u4eec\u6311\u91cd\u70b9\u5f3a\u8c03\u56de\u987e\uff0c\u4e5f\u4f1a\u7ed9\u540c\u5b66\u4eec\u8010\u5fc3\u7b54\u7591\u4ea4\u6d41\uff0c\u662f\u5f88\u597d\u7684\u8001\u5e08\uff01\uff08\u53ef\u80fd\u7684\u69fd\u70b9\u662f\u7ed9\u5206\u76f8\u5bf9\u6765\u8bf4\u6bd4\u8f83\u6c42\u662f\uff0c\u4e0d\u77e5\u9053\u662f\u8001\u5e08\u7684\u95ee\u9898\u8fd8\u662f\u8fd9\u95e8\u8bfe\u7684\u95ee\u9898\uff09</p> <p>\u5f20\u8fd0\u708e\u8001\u5e08\u5c31\u4e0d\u591a\u8bc4\u4ef7\u4e86\u3002\u3002\u3002\u8bb2\u8bfe\u6beb\u65e0\u91cd\u70b9\uff0c\u751a\u81f3\u907f\u5f00\u91cd\u70b9\u5f00\u59cb\u8bb2\u5668\u4ef6\u5de5\u827a\uff08\u8bb2\u4e09\u6781\u7ba1\u7684\u65f6\u5019\u5c0f\u4fe1\u53f7\u6a21\u578b\u90fd\u4e0d\u8bb2\uff0c\u5f00\u59cb\u8bb2\u63ba\u6742\uff09\uff0c\u7b54\u7591\u662f\u4e0d\u4f1a\u7684\uff0c\u8bb2\u8bfe\u662f\u4e00\u62cd\u8111\u888b\u60f3\u8bb2\u5565\u8bb2\u5565\u7684\uff0c\u4f5c\u4e1a\u662f\u778e\u5e03\u7f6e\u7684\uff0c\u8003\u8bd5\u8003\u5dee\u4e86\u8fd8\u662f\u8981yygq\u5b66\u751f\u7684\uff0c\u6700\u540e\u4e00\u8282\u8bfe\u662f\u8981\u201c\u5e0c\u671b\u4f60\u4eec\u4e0d\u8981\u5728\u7f51\u4e0a\u9a82\u6211\u201d\u7684...\u53ef\u80fd\u4ed6\u77e5\u9053\u81ea\u5df1\u4e0d\u9002\u5408\u8bb2\u8bfe\uff0c\u4e5f\u5c1d\u8bd5\u505a\u51fa\u4e00\u4e9b\u6539\u8fdb\uff0c\u4f46\u786e\u5b9e\u8bb2\u8bfe\u6548\u679c\u6ca1\u6709\u4ec0\u4e48\u5b9e\u8d28\u6027\u7684\u63d0\u5347...</p> <p>\u6211\u4eec\u8fd9\u4e00\u5c4a\u7684\u73ed\u5c48\u8001\u5e08\u51fa\u5dee\u7279\u522b\u591a\uff0c\u672c\u6765\u6574\u4e2a\u6a21\u7535\u90fd\u662f\u5f52\u5c48\u8001\u5e08\u7684\uff0c\u7ed3\u679c\u5f88\u591a\u90e8\u5206\u90fd\u7531\u7262\u5f20\u6765\u5e26\u4e86\uff0c\u5c48\u8001\u5e08\u56de\u6765\u5929\u90fd\u584c\u4e86\uff0c\u4e00\u95ee\u600e\u4e48\u4f60\u4eec\u4e09\u6781\u7ba1\u7684\u4e09\u79cd\u63a5\u6cd5\u90fd\u4e0d\u4f1a\uff0c\u5c0f\u4fe1\u53f7\u6a21\u578b\u4e0d\u4f1a\uff0c\u518d\u4e00\u95ee\u53d1\u73b0\u7262\u5f20\u90fd\u51e0\u4e4e\u4e0d\u8bb2\uff0cPPT\u4e0a\u8fc7\u4e86\u5c31\u771f\u7684\u8fc7\u4e86\uff0c\u4e8e\u662f\u53c8\u5f00\u59cb\u4ece\u5934\u7ed9\u7262\u5f20\u64e6\u5c41\u80a1...\u8fd9\u53ef\u80fd\u662f\u5bfc\u81f4\u4ed6\u8bb2\u8bfe\u901f\u5ea6\u6bd4\u8f83\u5feb\u7684\u4e00\u4e2a\u539f\u56e0\uff08\u4e5f\u53ef\u80fd\u662f\u6211\u4eec\u8fd9\u4e2a\u73ed\u6210\u7ee9\u90fd\u4e0d\u592a\u597d\u770b\u7684\u4e00\u4e2a\u539f\u56e0</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ec/#_4", "title": "\u7b14\u8bb0\u5206\u4eab", "text": "<p>CC98\u7248</p> <p></p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/isee/", "title": "ISEE", "text": "<p>I SEE the future.</p> <p>\u672c\u680f\u8bb0\u5f55\u4e0a\u8fc7\u7684\u6240\u6709\u4fe1\u7535\u4e13\u4e1a\u8bfe\uff08\u7406\u8bba\u8bfe\uff09\uff0c\u6309\u5b66\u671f\u8fdb\u884c\u5206\u7c7b\u5f52\u7eb3\uff1b \u8bfe\u7a0b\u5c06\u9644\u4e0a\u4e2a\u4eba\u4e3b\u89c2\u8bc4\u4ef7\u4ee5\u53ca\u4e00\u4e9b\u5b66\u4e60\u7ecf\u9a8c\uff0c\u90e8\u5206\u6807[\u7b14\u8bb0]\u7684\u8868\u793a\u5185\u542b\u7b14\u8bb0\u5206\u4eab~</p>"}, {"location": "notes/isee/isee/#_1", "title": "\u76ee\u5f55", "text": ""}, {"location": "notes/isee/isee/#_2", "title": "\u5927\u4e00\u79cb\u51ac", "text": "<ul> <li>\u4fe1\u606f\u4e0e\u7535\u5b50\u5de5\u7a0b\u5bfc\u8bba</li> </ul>"}, {"location": "notes/isee/isee/#_3", "title": "\u5927\u4e00\u6625\u590f", "text": "<p>\u65e0</p>"}, {"location": "notes/isee/isee/#_4", "title": "\u5927\u4e8c\u79cb\u51ac", "text": "<ul> <li>\u7535\u5b50\u7535\u8def\u57fa\u7840[\u7b14\u8bb0]</li> <li>\u96c6\u6210\u7535\u8def\u5bfc\u8bba\uff081.5\u5b66\u5206\uff09</li> </ul>"}, {"location": "notes/isee/isee/#_5", "title": "\u5927\u4e8c\u6625\u590f", "text": "<ul> <li>\u534a\u5bfc\u4f53\u7269\u7406[\u7b14\u8bb0]</li> <li>\u4fe1\u53f7\u4e0e\u7cfb\u7edf</li> </ul>"}, {"location": "notes/isee/semiconductorfundamentals/", "title": "\u534a\u5bfc\u4f53\u7269\u7406", "text": "<p>Instructor\uff1a\u7a0b\u7136</p> <p>Semaster\uff1a\u5927\u4e8c\u6625\u590f</p> <p>\u8bfe\u7a0b\u7c7b\u522b\uff1a\u4e13\u4e1a\u5fc5\u4fee</p> <p>\u63a8\u8350\u6307\u6570\uff1a</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/semiconductorfundamentals/#_1", "title": "\u8bfe\u7a0b\u603b\u7ed3", "text": "<p>\u5206\u6570\u6784\u6210\uff1a20%\u671f\u4e2d\u8003+30%\u671f\u672b\u8003\uff08\u5206\u522b\u5728\u6625\u516b\u5468\u3001\u590f\u516b\u5468\u968f\u5802\u8fdb\u884c\uff09</p> <p>\u524d\u534a\u5b66\u671f\u4e3b\u8981\u6d89\u53ca\u7269\u7406\u90e8\u5206\u7684\u77e5\u8bc6\uff08\u4ece\u6676\u683c\u3001\u884d\u5c04\u3001\u57fa\u7840\u91cf\u5b50\u529b\u5b66\u5230\u534a\u5bfc\u4f53\u63ba\u6742\uff0c\u6d89\u53ca\u5e7f\u4f46\u4e0d\u6df1\uff0c\u6709\u5927\u96fe\u57fa\u7840\u5c31\u5e94\u8be5\u95ee\u9898\u4e0d\u5927\uff09</p> <p>\u540e\u534a\u5b66\u671f\u4e3b\u8981\u6d89\u53ca\u534a\u5bfc\u4f53\u5668\u4ef6\u90e8\u5206\u7684\u77e5\u8bc6\uff08\u4ecePN\u7ed3\u3001\u4e8c\u6781\u7ba1\u5230\u4e09\u6781\u7ba1\u3001\u573a\u6548\u5e94\u7ba1\uff09\uff0c\u662f\u671f\u672b\u8003\u8bd5\u7684\u91cd\u70b9\u3002</p> <p>\u5c5e\u4e8e\u56fd\u9645\u5316\u8bfe\u7a0b\uff0c\u5168\u82f1\u6587\uff0c\u4f46\u662f\u8001\u5e08\u7684\u53e3\u8bed\u5f88\u597d\uff0c\u8bed\u901f\u4e5f\u4e0d\u662f\u5f88\u5feb\uff0c\u6211\u611f\u89c9\u667a\u4e911.5\u500d\u901f\u4e5f\u4e0d\u592a\u6709\u95ee\u9898</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/semiconductorfundamentals/#_2", "title": "\u5f00\u5377\u8d44\u6599", "text": "<p>CC98\u7248</p> <p></p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/robot/robotintro/", "title": "\u673a\u5668\u4eba\u5bfc\u8bba", "text": "<p>Instructor\uff1a\u738b\u9149\u3001\u6731\u79cb\u56fd\u3001\u5434\u4fca\u3001\u738b\u8d8a</p> <p>Semaster\uff1a\u5927\u4e8c\u6625\u590f</p> <p>\u8bfe\u7a0b\u7c7b\u522b\uff1a\u8de8\u4e13\u4e1a\uff08\u81ea\u52a8\u5316\u4e13\u4e1a\u8bfe\uff09</p> <p>\u63a8\u8350\u6307\u6570\uff1a</p>", "tags": ["\u7b14\u8bb0", "\u8de8\u4e13\u4e1a"]}, {"location": "notes/robot/robotintro/#_1", "title": "\u63d0\u7eb2\u5206\u4eab", "text": "", "tags": ["\u7b14\u8bb0", "\u8de8\u4e13\u4e1a"]}, {"location": "projects/projects/", "title": "\u76ee\u5f55", "text": "<p>\u672c\u680f\u8bb0\u5f55\u4e0a\u5927\u5b66\u4ee5\u6765\u53c2\u4e0e\u7684\u5927\u5927\u5c0f\u5c0f\u7684\u9879\u76ee\u4e0e\u5b9e\u8df5</p> <p></p>"}]}