9\u8010\u5fc3\uff1b\u8fd9\u5b66\u671f\u4f53\u9a8c\u4e86\u4e00\u628ayxf\uff0c\u8bb2\u8bfe\u6ca1\u6709\u903b\u8f91\u4e0d\u8bf4\uff0c\u7b54\u7591\u8fd8\u5f88\u4e0d\u8010\u70e6\uff0c\u5927\u90e8\u5206\u65f6\u5019\u8981\u505a\u4ec0\u4e48\u90fd\u4e0d\u8bf4\u6e05\u695a\uff0c\u8bc4\u5206\u4f4e\u4e0d\u662f\u6ca1\u6709\u7406\u7531\u7684...</p>", "tags": ["\u7b14\u8bb0", "\u5b9e\u9a8c"]}, {"location": "notes/experiment/dssy2/#_2", "title": "\u5b9e\u9a8c\u62a5\u544a", "text": "<ul> <li>\u8bbe\u8ba1\u62a5\u544a</li> </ul> <ul> <li>\u7efc\u5408\u62a5\u544a</li> </ul>", "tags": ["\u7b14\u8bb0", "\u5b9e\u9a8c"]}, {"location": "notes/experiment/generalphy/", "title": "\u666e\u901a\u7269\u7406\u5b66\u5b9e\u9a8cI", "text": "<p> \u7ea6 0 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4\u4e0d\u5230 1 \u5206\u949f</p>"}, {"location": "notes/experiment/sdsy/", "title": "\u6570\u5b57\u7cfb\u7edf\u8bbe\u8ba1\u5b9e\u9a8c", "text": "<p> \u7ea6 0 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4\u4e0d\u5230 1 \u5206\u949f</p>"}, {"location": "notes/isee/ai/", "title": "\u4eba\u5de5\u667a\u80fd", "text": "<p> \u7ea6 325 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4 1 \u5206\u949f</p> <p>Instructor\uff1a\u5f20\u5cad</p> <p>Semaster\uff1a\u5927\u4e8c\u6625\u590f</p> <p>\u8bfe\u7a0b\u7c7b\u522b\uff1a\u4e13\u4e1a\u5fc5\u4fee</p> <p>\u63a8\u8350\u6307\u6570\uff1a</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ai/#_1", "title": "\u8bfe\u7a0b\u6982\u8ff0", "text": "<p>\u4fe1\u7535\u5b66\u9662\u4e09\u4e2a\u4e13\u4e1a\u5171\u540c\u7684\u4e13\u4e1a\u8bfe\uff0c\u4e0d\u540c\u4e8e\u4eba\u5de5\u667a\u80fd\u57fa\u7840\uff0c\u4eba\u5de5\u667a\u80fd\u867d\u7136\u96be\u4f46\u662f\u771f\u7684\u80fd\u5b66\u5230\u5f88\u591a\u6709\u7528\u7684\u4e1c\u897f</p> <p>\u5206\u6570\u6784\u6210\uff1a\u5e73\u65f650%\uff08\u4f5c\u4e1a+\u70b9\u540d+\u5927\u4f5c\u4e1a\uff09 + \u671f\u672b\u8003\u8bd550%</p> <p>\u671f\u672b\u8003\u4e3a\u534a\u5f00\u5377\uff0c\u5141\u8bb8\u5e26\u4e00\u5f20\u6b63\u53cd\u4e24\u9762\u7684\u9996\u5148A4\u7eb8\uff08\u53ef\u7535\u5b50\u624b\u5199\uff09\uff1b\u8bfe\u7a0b\u6574\u4f53\u96be\u5ea6\u8f83\u5927\uff0c\u6db5\u76d6\u4e86\u641c\u7d22\u3001\u5bf9\u6297\u641c\u7d22\u3001\u7ea6\u675f\u6ee1\u8db3\u3001\u8d1d\u53f6\u65af\u7f51\u7edc\u3001\u6df1\u5ea6\u5b66\u4e60\u3001\u5f3a\u5316\u5b66\u4e60\u7b49\u5185\u5bb9\uff0c\u4f46\u671f\u672b\u8003\u96be\u5ea6\u4e0d\u7b97\u5f88\u5927\uff0c\u9898\u578b\u57fa\u672c\u56fa\u5b9a\u3001\u89e3\u9898\u65b9\u6cd5\u4e5f\u8f83\u4e3a\u56fa\u5b9a\uff0c\u4e0e\u5e73\u65f6\u4f5c\u4e1a\u9898\u548c\u5386\u5e74\u5377\u7684\u9898\u8f83\u50cf\uff08\u4e0d\u8fc7\u636e\u4e86\u89e3\u6709\u7684\u8001\u5e08\u73ed\u5e73\u65f6\u4f5c\u4e1a\u4e0d\u4f1a\u5e03\u7f6e\u7406\u8bba\u9898\uff0c\u4f46\u5f20\u8001\u5e08\u73ed\u662f\u57fa\u672c\u6bcf\u4e00\u7ae0\u90fd\u4f1a\u6709\u7406\u8bba\u4f5c\u4e1a\u9898\u7684\uff09</p> <p>\u5f15\u7528\u67e5\u8001\u5e08\u4e0a\u5f20\u5cad\u8001\u5e08\u7684\u8bc4\u4ef7\uff1a</p> <p>\u5cad\u795e\uff0c\u8ba4\u771f\u8d1f\u8d23\uff0c\u6307\u5bfc\u7ec6\u5fc3\uff0c\u4e3a\u4eba\u6e29\u548c\u5112\u96c5\uff0c\u6709\u541b\u5b50\u4e4b\u98ce</p> <p>\u76f8\u5f53\u4e2d\u80af\uff01\u5370\u8c61\u6700\u6df1\u7684\u662f\u6700\u540e\u4e00\u8282\u8bfe\u5927\u4f5c\u4e1a\u7684\u6c47\u62a5\uff0c\u4e0a\u8bfe\u4e4b\u524d\u4ed6\u4e25\u8083\u6de1\u5b9a\u5730\u8bf4\u4e86\u4e00\u53e5\uff0c\u201c\u6211\u8001\u5a46\u5728\u533b\u9662\u5feb\u751f\u4e86...\u201d\uff0c\u5168\u573a\u9aa4\u7136\u638c\u58f0\u96f7\u52a8...</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ai/#a4-cheat-sheet", "title": "\u4eba\u5de5\u667a\u80fdA4 Cheat Sheet", "text": "", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/digital_system_design/", "title": "\u6570\u5b57\u7cfb\u7edf\u8bbe\u8ba1", "text": "<p> \u7ea6 343 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4 1 \u5206\u949f</p> <p>Instructor\uff1a\u5218\u9e4f</p> <p>Semaster\uff1a\u5927\u4e8c\u6625\u590f</p> <p>\u8bfe\u7a0b\u7c7b\u522b\uff1a\u4e13\u4e1a\u5fc5\u4fee</p> <p>\u63a8\u8350\u6307\u6570\uff1a</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/digital_system_design/#_1", "title": "\u8bfe\u7a0b\u6982\u8ff0", "text": "<p>\u6570\u5b57\u7cfb\u7edf\u8bbe\u8ba1\uff08\u6570\u7535\uff09\u662f\u5fae\u7535\u5b50\u548c\u4fe1\u5de5\u5927\u4e8c\u7684\u4e13\u4e1a\u8bfe\uff0c\u4e0d\u540c\u4e8e\u7535\u79d1\u5927\u4e00\u7684\u6570\u7535\uff08\u6570\u5b57\u7cfb\u7edf\uff09\uff0c\u76f8\u5bf9\u6765\u8bf4\u66f4\u786c\u4e00\u70b9</p> <p>\u5206\u6570\u6784\u6210\uff1a\u5e73\u65f640% + \u671f\u672b\u95ed\u5377\u800360%\uff08\u5413\u54ed\u4e86\uff09</p> <p>\u5e73\u65f6\u5206\u6570\u4e3b\u8981\u7531\u82e5\u5e72\u6b21\u4f5c\u4e1a\u4ee5\u53ca\u4e09\u6b21\u5c0f\u6d4b\u3001\u4e00\u6b21\u671f\u4e2d\u8003\u7ec4\u6210\uff08lp\u73ed\u662f\u8fd9\u6837\uff0c\u9694\u58c1wwd\u73ed\u8fd8\u6709\u4e00\u4e2a\u5927\u4f5c\u4e1a\u53ef\u80fd\u4e0d\u592a\u4e00\u6837\uff09</p> <p>\u5185\u5bb9\u4e3b\u8981\u6db5\u76d6\u95e8\u7535\u8def\uff08CMOS\u3001TTL\uff09\u3001\u7ec4\u5408\u903b\u8f91\u3001\u89e6\u53d1\u5668\u3001\u65f6\u5e8f\u903b\u8f91\u3001\u8109\u51b2\u7535\u8def\u3001\u63a7\u5236\u5668\u7b49\uff0c\u6211\u611f\u89c9\u6d59\u6c5f\u9ad8\u4e2d\u7684\u6280\u672f\u5df2\u7ecf\u6db5\u76d6\u4e86\u6570\u7535\u4e00\u534a\u7684\u5185\u5bb9\u4e86\uff08</p> <p>lp\u5728\u6570\u7535\u4ec5\u6709\u7684\u4e24\u4e2a\u8001\u5e08\u4e2d\u7b97\u6bd4\u8f83\u597d\u7684\u4e00\u4e2a\uff08wwd\u7531\u4e8e\u6bcf\u5e74\u90fd\u5728\u671f\u672b\u8003\u671f\u95f4\u5e03\u7f6e\u5927\u4f5c\u4e1a\u800c\u6df1\u6df1\u88ab\u4eba\u8bdf\u75c5\uff0clp\u73ed\u751a\u81f3\u90fd\u6ca1\u6709\u5927\u4f5c\u4e1a\uff09\uff0c\u4f46\u662f\u4e2a\u4eba\u8ba4\u4e3a\u4ed6\u7684\u8bb2\u8bfe\u8fd8\u662f\u6709\u70b9\u6ca1\u6709\u5c42\u6b21\u548c\u903b\u8f91\uff0c\u5f88\u591a\u5730\u65b9\u8fd8\u8981\u81ea\u5b66\u4e00\u904d\uff08\u7279\u522b\u662f\u95e8\u7535\u8def\u3001\u8109\u51b2\u7535\u8def\u7b49\u548c\u6a21\u7535\u5173\u8054\u6bd4\u8f83\u5927\u7684\u5730\u65b9\uff1b\u4ed6\u504f\u504f\u8fd8\u8003\u7684\u591a\uff09</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/digital_system_design/#_2", "title": "\u8d44\u6599\u5206\u4eab", "text": "<ul> <li>\u8865\u5929\u7b14\u8bb0\uff08\u4e3b\u8981\u9488\u5bf9\u6211\u4e2a\u4eba\u7684\u6f0f\u6d1e\uff09</li> </ul> <ul> <li>\u5c0f\u6d4b\u3001\u671f\u4e2d\u8003\u5377</li> </ul> <ul> <li>\u671f\u672b\u8003\u56de\u5fc6\u9898 (\u53ea\u56de\u5fc6\u4e86\u90a3\u9053\u5341\u5206\u8be1\u5f02\u7684\u95e8\u7535\u8def\u9898)</li> </ul>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ec/", "title": "\u7535\u5b50\u7535\u8def\u57fa\u7840", "text": "<p> \u7ea6 676 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4 2 \u5206\u949f</p> <p>Instructor\uff1a\u5c48\u4e07\u56ed\u3001\u5f20\u8fd0\u708e</p> <p>Semaster\uff1a\u5927\u4e8c\u79cb\u51ac</p> <p>\u8bfe\u7a0b\u7c7b\u522b\uff1a\u4e13\u4e1a\u5fc5\u4fee</p> <p>\u63a8\u8350\u6307\u6570\uff1a\uff08\u4f46\u662f\u662f\u6574\u4e2a\u5b66\u9662\u5fc5\u4fee\uff0c\u4e0d\u60f3\u4fee\u4e5f\u6ca1\u529e\u6cd5\uff09</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ec/#_1", "title": "\u8bfe\u7a0b\u6982\u8ff0", "text": "", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ec/#_2", "title": "\u5173\u4e8e\u8bfe\u7a0b", "text": "<ul> <li>\u4fe1\u7535\u56db\u5927\u5929\u4e66\u4e4b\u4e00</li> <li>\u5c0f\u65f6\u5019\u77e5\u9053\u4ee5\u540e\u8981\u5b66\u6a21\u7535\u5413\u54ed\u4e86</li> <li>\u50ac\u751f\u79cd\u79cd\u77e5\u540did\u201c\u5b66\u4e0d\u6765\u6a21\u7535\u201d\u3001\u201c\u4e0d\u5b66\u7535\u57fa\u201d...</li> </ul> <p>\u8bfe\u7a0b\u6574\u4f53\u6db5\u76d6\u7535\u8def\u539f\u7406\u4e0e\u6a21\u62df\u7535\u8def\u4e24\u4e2a\u90e8\u5206\uff1b\u7535\u8def\u539f\u7406\u90e8\u5206\u76f8\u5bf9\u7b80\u5355\uff0c\u4e3b\u8981\u662f\u57fa\u5c14\u970d\u592b\u5b9a\u5f8b\u3001\u7b49\u6548\u7535\u8def\u5b9a\u5f8b\u4ee5\u53caRC\u7535\u8def\u77ac\u6001\u54cd\u5e94\u5206\u6790\u7b49\u5185\u5bb9\uff0c\u7ed3\u5408\u7535\u8bbe\u5b9e\u9a8cI\u98df\u7528\u4f1a\u8f83\u597d\u7406\u89e3\uff1b</p> <p>\u6a21\u7535\u90e8\u5206\u5c31\u5f00\u59cb\u5929\u4e66\u4e86\uff0cBJT\u4e0eFET\u7684\u5c0f\u4fe1\u53f7\u5206\u6790\u3001\u53cd\u9988\u3001\u9891\u7387\u54cd\u5e94\u3001\u529f\u653e\u7b49\uff0c\u4ed9\u4e4b\u4eba\u516e\u5217\u5982\u9ebb...\u6211\u4eec\u867d\u7136\u6982\u5ff5\u4e0a\u4e0d\u597d\u7406\u89e3\uff0c\u4f46\u662f\u4e5f\u4e0d\u597d\u8ba1\u7b97\u554a\uff08\u7279\u522b\u662f24\u7ea7\u7684\u8003\u8bd5\uff0c\u8fd9\u9898\u592a\u591a\u4e86\uff0c\u8ba1\u7b97\u5668\u90fd\u6765\u4e0d\u53ca\u6441.jpg\uff09\u4f46\u662f\u6a21\u7535\u53c8\u6bd4\u8f83\u91cd\u8981\uff0c\u5efa\u8bae\u591a\u82b1\u4e00\u4e9b\u65f6\u95f4\u5b66\uff0c\u867d\u7136\u8fd9\u6837\u4e0d\u4e00\u5b9a\u80fd\u8ba9\u4f60\u62ff\u5230\u6bd4\u8f83\u597d\u7684\u6210\u7ee9\uff0c\u4f46\u5bf9\u4e8e\u4e4b\u540e\u7684\u7535\u8def\u8bfe\u8fd8\u662f\u6709\u4e00\u4e9b\u5e2e\u52a9\u7684\u3002</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ec/#_3", "title": "\u5173\u4e8e\u8001\u5e08", "text": "<p>\u5c48\u4e07\u56ed\u8001\u5e08\u4e0a\u8bfe\u6bd4\u8f83\u6e05\u6670\u6709\u903b\u8f91\uff0c\u6574\u4f53\u4e0a\u6bd4\u8f83\u5feb\u4f46\u662f\u4f1a\u7ed9\u540c\u5b66\u4eec\u6311\u91cd\u70b9\u5f3a\u8c03\u56de\u987e\uff0c\u4e5f\u4f1a\u7ed9\u540c\u5b66\u4eec\u8010\u5fc3\u7b54\u7591\u4ea4\u6d41\uff0c\u662f\u5f88\u597d\u7684\u8001\u5e08\uff01\uff08\u53ef\u80fd\u7684\u69fd\u70b9\u662f\u7ed9\u5206\u76f8\u5bf9\u6765\u8bf4\u6bd4\u8f83\u6c42\u662f\uff0c\u4e0d\u77e5\u9053\u662f\u8001\u5e08\u7684\u95ee\u9898\u8fd8\u662f\u8fd9\u95e8\u8bfe\u7684\u95ee\u9898\uff09</p> <p>\u5f20\u8fd0\u708e\u8001\u5e08\u5c31\u4e0d\u591a\u8bc4\u4ef7\u4e86\u3002\u3002\u3002\u8bb2\u8bfe\u6beb\u65e0\u91cd\u70b9\uff0c\u751a\u81f3\u907f\u5f00\u91cd\u70b9\u5f00\u59cb\u8bb2\u5668\u4ef6\u5de5\u827a\uff08\u8bb2\u4e09\u6781\u7ba1\u7684\u65f6\u5019\u5c0f\u4fe1\u53f7\u6a21\u578b\u90fd\u4e0d\u8bb2\uff0c\u5f00\u59cb\u8bb2\u63ba\u6742\uff09\uff0c\u7b54\u7591\u662f\u4e0d\u4f1a\u7684\uff0c\u8bb2\u8bfe\u662f\u4e00\u62cd\u8111\u888b\u60f3\u8bb2\u5565\u8bb2\u5565\u7684\uff0c\u4f5c\u4e1a\u662f\u778e\u5e03\u7f6e\u7684\uff0c\u8003\u8bd5\u8003\u5dee\u4e86\u8fd8\u662f\u8981yygq\u5b66\u751f\u7684\uff0c\u6700\u540e\u4e00\u8282\u8bfe\u662f\u8981\u201c\u5e0c\u671b\u4f60\u4eec\u4e0d\u8981\u5728\u7f51\u4e0a\u9a82\u6211\u201d\u7684...\u53ef\u80fd\u4ed6\u77e5\u9053\u81ea\u5df1\u4e0d\u9002\u5408\u8bb2\u8bfe\uff0c\u4e5f\u5c1d\u8bd5\u505a\u51fa\u4e00\u4e9b\u6539\u8fdb\uff0c\u4f46\u786e\u5b9e\u8bb2\u8bfe\u6548\u679c\u6ca1\u6709\u4ec0\u4e48\u5b9e\u8d28\u6027\u7684\u63d0\u5347...</p> <p>\u6211\u4eec\u8fd9\u4e00\u5c4a\u7684\u73ed\u5c48\u8001\u5e08\u51fa\u5dee\u7279\u522b\u591a\uff0c\u672c\u6765\u6574\u4e2a\u6a21\u7535\u90fd\u662f\u5f52\u5c48\u8001\u5e08\u7684\uff0c\u7ed3\u679c\u5f88\u591a\u90e8\u5206\u90fd\u7531\u7262\u5f20\u6765\u5e26\u4e86\uff0c\u5c48\u8001\u5e08\u56de\u6765\u5929\u90fd\u584c\u4e86\uff0c\u4e00\u95ee\u600e\u4e48\u4f60\u4eec\u4e09\u6781\u7ba1\u7684\u4e09\u79cd\u63a5\u6cd5\u90fd\u4e0d\u4f1a\uff0c\u5c0f\u4fe1\u53f7\u6a21\u578b\u4e0d\u4f1a\uff0c\u518d\u4e00\u95ee\u53d1\u73b0\u7262\u5f20\u90fd\u51e0\u4e4e\u4e0d\u8bb2\uff0cPPT\u4e0a\u8fc7\u4e86\u5c31\u771f\u7684\u8fc7\u4e86\uff0c\u4e8e\u662f\u53c8\u5f00\u59cb\u4ece\u5934\u7ed9\u7262\u5f20\u64e6\u5c41\u80a1...\u8fd9\u53ef\u80fd\u662f\u5bfc\u81f4\u4ed6\u8bb2\u8bfe\u901f\u5ea6\u6bd4\u8f83\u5feb\u7684\u4e00\u4e2a\u539f\u56e0\uff08\u4e5f\u53ef\u80fd\u662f\u6211\u4eec\u8fd9\u4e2a\u73ed\u6210\u7ee9\u90fd\u4e0d\u592a\u597d\u770b\u7684\u4e00\u4e2a\u539f\u56e0</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ec/#_4", "title": "\u7b14\u8bb0\u5206\u4eab", "text": "<p>CC98\u7248</p> <p></p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ic_intro/", "title": "\u96c6\u6210\u7535\u8def\u5bfc\u8bba", "text": "<p> \u7ea6 578 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4 2 \u5206\u949f</p> <p>Instructor\uff1a\u5434\u6c49\u660e\u3001\u7a0b\u7136\u3001\u4fde\u6ee8\u3001\u865e\u5c0f\u9e4f</p> <p>Semaster\uff1a\u5927\u4e8c\u79cb\u51ac</p> <p>\u8bfe\u7a0b\u7c7b\u522b\uff1a\u4e13\u4e1a\u5fc5\u4fee/\u901a\u8bc6\u9009\u4fee</p> <p>\u63a8\u8350\u6307\u6570\uff1a</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/ic_intro/#_1", "title": "\u8bfe\u7a0b\u603b\u7ed3", "text": "<p>\u5148\u8bf4\u7ed3\u8bba\uff1a\u975e\u5e38\u63a8\u8350\u5fae\u7535\u5b50\u7684\u540c\u5b66\u90fd\u6765\u4e0a\u8fd9\u95e81.5\u5b66\u5206\u7684\u96c6\u7535\u5bfc\uff08\u53ef\u4ee5\u66ff\u4ee32\u5b66\u5206\u7684\u4e13\u4e1a\u8bfe\uff09\uff0c\u4e5f\u63a8\u8350\u5176\u4ed6\u540c\u5b66\u4f5c\u4e3a\u901a\u8bc6\u8bfe\u9009\u4fee~</p> <p>\u8bfe\u7a0b\u4ee5\u201c\u901a\u8bc6\u8bfe\u6bd4\u4e13\u4e1a\u8bfe\u8fd8\u786c\u6838\u201d\u95fb\u540d\uff0c\u5185\u5bb9\u6db5\u76d6\u4e86\u96c6\u6210\u7535\u8def\u5236\u9020\u53d1\u5c55\u5386\u7a0b\u3001\u5355\u6b65\u5de5\u827a\u3001\u6838\u5fc3\u5de5\u827a\u3001\u5c01\u88c5\u6d4b\u8bd5\u7b49\u6d41\u7a0b\uff0c\u6d89\u53ca\u77e5\u8bc6\u591a\u3001\u6db5\u76d6\u8303\u56f4\u5e7f\uff1b\u800c\u4e14\u5927\u90e8\u5206\u77e5\u8bc6\u786e\u5b9e\u6bd4\u8f83\u786c\u6838\uff0c\u5bf9\u4e8e\u5fae\u7535\u5b50\u4e13\u4e1a\u5927\u4e8c\u7684\u5b66\u751f\u90fd\u6709\u4e00\u4e9b\u96be\u4ee5\u6d88\u5316\uff0c\u66f4\u522b\u8bf4\u628a\u8fd9\u95e8\u8bfe\u5f53\u901a\u8bc6\u9009\u4fee\u4e0a\u7684\u5927\u4e00\u540c\u5b66\uff1b\u6bd4\u8d77\u5fae\u7535\u5b50\u4e13\u4e1a\u53e6\u4e00\u95e8\u4e24\u5b66\u5206\u7684\u4e13\u4e1a\u8bfe\u96c6\u6210\u7535\u8def\u5bfc\u8bba\uff08PPT\u5927\u8d5b\uff09\uff0c\u8fd9\u95e8\u8bfe\u786e\u5b9e\u66f4\u80fd\u5b66\u5230\u4e1c\u897f\uff0c\u4e5f\u786c\u6838\u5730\u591a...</p> <p>\u4f46\u662f\u4e0d\u8981\u88ab\u8fd9\u4e9b\u5413\u6015\u4e86\uff0c\u56e0\u4e3a\uff1a</p> <p>\u8fd9\u95e8\u8bfe\u7684\u8001\u5e08\u90fd\u975e\u5e38\u7684\u597d\uff01\u5434\u6c49\u660e\u9662\u58eb\u3001\u7a0b\u7136\u8001\u5e08\u3001\u4fde\u658c\u8001\u5e08\u90fd\u975e\u5e38\u7684\u4eb2\u5207\uff0c\u8bb2\u8bfe\u6709\u91cd\u70b9\uff0c\u4e5f\u4f1a\u7167\u987e\u5230\u5927\u5bb6\u7684\u6c34\u5e73\u4e0d\u4f1a\u4e00\u4e0b\u8bb2\u5f88\u6df1\u7684\u4e1c\u897f\uff08\u8fd9\u95e8\u8bfe\u8ba9\u6211\u8ba4\u8bc6\u4e86cr\u8001\u5e08\u548cyb\u8001\u5e08\uff0c\u4e4b\u540e\u4e24\u5b66\u671f\u679c\u65ad\u9009\u4e86\u4ed6\u4eec\u7684\u5168\u82f1\u6587\u534a\u5bfc\u4f53\u7269\u7406\u548c\u5fae\u7535\u5b50\u5668\u4ef6\uff09\uff1b\u865e\u5c0f\u9e4f\u8001\u5e08\u76f8\u5bf9\u6765\u8bf4\u8bb2\u8bfe\u6bd4\u8f83\u6709\u81ea\u5df1\u7684\u98ce\u683c\uff0c\u559c\u6b22\u6ee1\u6559\u5ba4\u8dd1\u6765\u8dd1\u53bb\u63d0\u95ee\u4ee5\u53ca\u626f\u76ae\uff08bushi\uff09\uff0c\u4f46\u8bb2\u8bfe\u4e5f\u5f88\u6709\u6c34\u5e73\uff0c\u6574\u4f53\u6765\u8bf4\u8fd9\u95e8\u8bfe\u7684\u8001\u5e08\u90fd\u662f\u795e\u4ed9\u7ea7\u522b\u7684\u8001\u5e08</p> <p>\u53e6\u5916\u8bfe\u7a0b\u5e73\u65f6\u53ea\u6709\u4e24\u6b21\u5c0f\u4f5c\u4e1a\uff0c\u53ea\u8981\u82b1\u4e0a\u8bfe\u7684\u65f6\u95f4\u628a\u8001\u5e08\u8bb2\u7684\u542c\u4e2a\u5927\u6982\u5c31\u597d\u4e86\uff0c\u4f5c\u4e1a\u6bd4\u8f83\u96be\u53ef\u4ee5ai\u4e00\u4e0b\uff08\uff09\uff0c\u5e73\u65f6\u76f8\u5bf9\u6bd4\u8f83\u8f7b\u677e\uff1b \u8003\u8bd5\u662f\u5f00\u5377\uff0c\u53ef\u4ee5\u628a\u8001\u5e08\u7684PPT\u90fd\u6253\u5370\u4e0b\u6765\uff08\u8fd9\u5f97\u82b1\u4e0d\u5c11\u94b1.jpg\uff09\uff0c\u53e6\u5916\u4e5f\u5efa\u8bae\u628a\u4f5c\u4e1a\u548c\u7b54\u6848\u6253\u5370\u4e0b\u6765\uff0c\u590d\u4e60\u7684\u65f6\u5019\u53ef\u4ee5\u56de\u987e\u4e00\u4e0b\u4f5c\u4e1a\uff0c\u628a\u6bcf\u4e00\u9898\u90fd\u641e\u61c2\uff0c\u56e0\u4e3a\u8003\u8bd5\u7684\u9898\u76ee\u548c\u4f5c\u4e1a\u6bd4\u8f83\u7c7b\u4f3c\u3002</p> <p>\u6700\u540e\u7ed9\u5206\u4e0d\u7b97\u7279\u522b\u597d\uff0c\u4f46\u51b2\u7740\u8fd9\u95e8\u8bfe\u7684\u8001\u5e08\u4ee5\u53ca\u80fd\u5b66\u5230\u5927\u91cf\u4e1c\u897f\uff0c\u8ba9\u6211\u518d\u9009\u4e00\u6b21\u6211\u8fd8\u662f\u4f1a\u6beb\u4e0d\u72b9\u8c6b\u7684\u9009\u8fd9\u95e8\u8bfe~</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/isee/", "title": "ISEE", "text": "<p> \u7ea6 140 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4\u4e0d\u5230 1 \u5206\u949f</p> <p>I SEE the future.</p> <p>\u672c\u680f\u8bb0\u5f55\u4e0a\u8fc7\u7684\u6240\u6709\u4fe1\u7535\u4e13\u4e1a\u8bfe\uff08\u7406\u8bba\u8bfe\uff09\uff0c\u6309\u5b66\u671f\u8fdb\u884c\u5206\u7c7b\u5f52\u7eb3\uff1b \u8bfe\u7a0b\u5c06\u9644\u4e0a\u4e2a\u4eba\u4e3b\u89c2\u8bc4\u4ef7\u4ee5\u53ca\u4e00\u4e9b\u5b66\u4e60\u7ecf\u9a8c\uff0c\u90e8\u5206\u6807[\u7b14\u8bb0]\u7684\u8868\u793a\u5185\u542b\u7b14\u8bb0\u5206\u4eab~</p>"}, {"location": "notes/isee/isee/#_1", "title": "\u76ee\u5f55", "text": ""}, {"location": "notes/isee/isee/#_2", "title": "\u5927\u4e00\u79cb\u51ac", "text": "<ul> <li>\u4fe1\u606f\u4e0e\u7535\u5b50\u5de5\u7a0b\u5bfc\u8bba</li> </ul>"}, {"location": "notes/isee/isee/#_3", "title": "\u5927\u4e00\u6625\u590f", "text": "<p>\u65e0</p>"}, {"location": "notes/isee/isee/#_4", "title": "\u5927\u4e8c\u79cb\u51ac", "text": "<ul> <li>\u7535\u5b50\u7535\u8def\u57fa\u7840[\u7b14\u8bb0]</li> <li>\u96c6\u6210\u7535\u8def\u5bfc\u8bba\uff081.5\u5b66\u5206\uff09</li> </ul>"}, {"location": "notes/isee/isee/#_5", "title": "\u5927\u4e8c\u6625\u590f", "text": "<ul> <li>\u534a\u5bfc\u4f53\u7269\u7406[\u7b14\u8bb0]</li> <li>\u4fe1\u53f7\u4e0e\u7cfb\u7edf</li> <li>\u6570\u5b57\u7cfb\u7edf\u8bbe\u8ba1[\u7b14\u8bb0]</li> <li>\u4eba\u5de5\u667a\u80fd[\u7b14\u8bb0]</li> </ul>"}, {"location": "notes/isee/isee_intro/", "title": "\u4fe1\u606f\u4e0e\u7535\u5b50\u5de5\u7a0b\u5bfc\u8bba", "text": "<p> \u7ea6 748 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4 2 \u5206\u949f</p> <p>Instructor\uff1a\u7ae0\u732e\u6c11</p> <p>Semaster\uff1a\u5927\u4e00\u79cb\u51ac</p> <p>\u8bfe\u7a0b\u7c7b\u522b\uff1a\u4e13\u4e1a\u5fc5\u4fee</p> <p>\u63a8\u8350\u6307\u6570\uff1a</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/isee_intro/#_1", "title": "\u8bfe\u7a0b\u6982\u8ff0", "text": "<p>\uff08\u524d\uff09\u9662\u957f\u7684\u8bfe\uff01\u975e\u5e38\u548c\u853c\u53ef\u4eb2\u7684\u8001\u5e08\uff0c\u8bb2\u8bfe\u7684\u65f6\u5019\u4e00\u76f4\u7b11\u772f\u772f\u7684\uff0c\u8bfe\u4e0b\u4e5f\u4f1a\u5f88\u8010\u5fc3\u7684\u7b54\u7591\uff1b\u53e6\u5916\u9662\u957f\u53c2\u4e0e\u4e86\u6559\u6750\u7684\u7f16\u5199\uff0c\u5bf9\u4e8e\u6559\u6750\u8fd8\u662f\u5403\u5f97\u6bd4\u8f83\u900f\u7684\uff0c\u8bb2\u8bfe\u6709\u6df1\u5ea6\u4f46\u662f\u53c8\u80fd\u61c2\u3002\u552f\u4e00\u53ef\u80fd\u7684\u96f7\u70b9\u662f\uff0c\u7ae0\u8001\u5e08\u5176\u5b9e\u8bb2\u8bfe\u76f8\u5bf9\u6765\u8bf4\u6ca1\u6709\u7279\u522b\u6709\u903b\u8f91\uff0c\u7279\u522b\u662f\u76f8\u6bd4\u8d77\u9694\u58c1\u53f2\u6cbb\u56fd\u8001\u5e08\u548c\u5176\u4ed6\u51e0\u4e2a\u8001\u5e08\uff0c\u4f46\u770b\u7684\u51fa\u6765\u786e\u5b9e\u662f\u5728\u52aa\u529b\u628a\u8bfe\u8bb2\u597d\u7684\u3002\u53e6\u5916\u4fe1\u7535\u5bfc\u7684\u7ed9\u5206\u90fd\u76f8\u5f53nice\uff0c\u56e0\u6b64\u4e0d\u7528\u592a\u5728\u610f\u54ea\u4e2a\u8001\u5e08\uff0c\u76f4\u63a5\u5927\u80c6\u9009\u5c31\u884c~</p> <p>\u6211\u662f\u5927\u4e00\u79cb\u51ac\u7684\u65f6\u5019\u5c31\u51c6\u5907\u8f6c\u4e13\u4e1a\u5230\u4fe1\u7535\uff0c\u56e0\u6b64\u63d0\u524d\u7814\u7a76\u4e86\u4e00\u4e0b\u8f6c\u4e13\u4e1a\u8981\u6c42\u7684\u524d\u7f6e\u8bfe\u8868\uff0c\u6700\u540e\u9009\u4e86\u4fe1\u7535\u5bfc\u8fd9\u95e8\u8bfe\uff1b\u4e00\u5f00\u59cb\u62c5\u5fc3\u8ddf\u4e0d\u4e0a\u8fdb\u5ea6\uff0c\u540e\u6765\u53d1\u73b0\u5403\u9ad8\u4e2d\u6280\u672f\u8001\u672c\u5c31\u884c\u4e86\u4e0d\u662f\u6d59\u6c5f\u6216\u8005\u9ad8\u4e2d\u6ca1\u5b66\u6280\u672f\u7684\u540c\u5b66\u4e5f\u4e0d\u7528\u62c5\u5fc3\uff0c\u8bfe\u7a0b\u7684\u5185\u5bb9\u6574\u4f53\u4e0a\u8fd8\u662f\u504f\u4ecb\u7ecd\u6027\u7684\uff0c\u8003\u8bd5\u4e5f\u662f\u5f00\u5377\uff08\u53ea\u80fd\u5e26\u8bfe\u672c\uff09\uff0c\u6700\u540e\u7ed9\u5206\u4e5f\u666e\u904d\u6bd4\u8f83\u597d\u3002</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/isee_intro/#_2", "title": "\u5927\u4f5c\u4e1a", "text": "<p>\u4fe1\u7535\u5bfc\u9971\u53d7\u8bdf\u75c5\u3001\u5f88\u591a\u5916\u4e13\u4e1a\u540c\u5b66\u4e0d\u6562\u5f53\u8de8\u4e13\u4e1a\u9009\u7684\u4e00\u4e2a\u539f\u56e0\u662f\u8bfe\u7a0b\u7684\u5927\u4f5c\u4e1a\u2014\u2014\u7528\u4e07\u5e74\u4e0d\u6362\u7684\u9762\u5305\u677f\u642d\u4e07\u5e74\u4e0d\u53d8\u76844bit\u52a0\u6cd5\u5668\u3002</p> <p>\u5bf9\u4e8e\u5927\u4e00\u7684\u540c\u5b66\u6765\u8bf4\uff0c\u8fd8\u6ca1\u6709\u63a5\u89e6\u6570\u7535\u4e2d\u7684\u95e8\u7535\u8def\uff0c\u5bf9\u4e8e\u4e0e\u95e8\u3001\u6216\u95e8\u7684\u642d\u6cd5\u5b8c\u5168\u662f\u81ea\u5df1\u94bb\u7814\u51fa\u6765\u7684\uff1b\u9762\u5305\u677f\u5927\u90e8\u5206\u540c\u5b66\u4e5f\u6ca1\u6709\u63a5\u89e6\u8fc7\uff0c\u4e0a\u624b\u8fd8\u9700\u8981\u4e00\u5b9a\u7684\u65f6\u95f4\uff1b\u6700\u6298\u78e8\u7684\u662f\uff0c\u4fe1\u7535\u63d0\u4f9b\u7684\u9762\u5305\u677f\u8d28\u91cf\u8fd8\u826f\u83a0\u4e0d\u9f50\uff08\u4f60\u5c31\u975e\u5f97\u8fd9\u4e48\u62a0\u5417\uff09\uff0c\u5728\u8c03\u8bd5\u4e0a\u52a8\u4e0d\u52a8\u5c31\u53d1\u73b0\u4e00\u6839\u7ebf\u65ad\u4e86\uff0c\u5c31\u7b97\u5b8c\u6210\u8bbe\u8ba1\u548c\u642d\u5efa\u8fd8\u8981\u82b1\u5927\u91cf\u65f6\u95f4\u8c03\u8bd5...</p> <p>\u6240\u5e78\u6211\u8fd8\u7b97\u6bd4\u8f83\u6709\u57fa\u7840\uff0c\u5bf9\u4e8e\u9762\u5305\u677f\u7684\u642d\u5efa\u4e5f\u80fd\u6bd4\u8f83\u5feb\u7684\u4e0a\u624b\uff0c\u6700\u540e\u7684\u7535\u8def\u90e8\u5206\u76f4\u63a5\u4e00\u4e2a\u4eba\u642d\u5b8c\u8c03\u8bd5\u5b8c\u4e86\uff08\uff09\u62a5\u544a\u90e8\u5206\u5c31\u8f9b\u82e6\u961f\u53cb\u591a\u5199\u4e00\u70b9\u4e86</p> <p>\u5728\u642d\u5efa\u8fc7\u7a0b\u4e2d\u6709\u4e00\u4e9b\u7ecf\u9a8c\u603b\u7ed3\uff1a</p> <ul> <li>\u5f3a\u70c8\u5efa\u8bae\u81ea\u5df1\u4e70\u4e00\u5757\u4e00\u6837\u7684\u9762\u5305\u677f</li> <li>\u5982\u679c\u662f\u7528\u5b66\u6821\u53d1\u7684\u9762\u5305\u677f\uff0c\u5efa\u8bae\u5148\u68c0\u67e5\u6e05\u695a\u54ea\u4e9b\u5b54\u4e4b\u95f4\u662f\u4e0d\u901a\u7684</li> <li>\u5584\u7528\u4e07\u7528\u8868</li> <li>\u642d\u5efa\u7684\u65f6\u5019\u53ef\u4ee5\u6309\u7167\u4e00\u5b9a\u7684\u89c4\u8303\uff0c\u6bd4\u5982\u9762\u5305\u677f\u56db\u4e2a\u533a\u57df\u521a\u597d\u5206\u7ed9\u56db\u7ea7\u5168\u52a0\u5668</li> <li>\u5f3a\u70c8\u5efa\u8bae\u642d\u5b8c\u4e00\u7ea7\u68c0\u67e5\u4e00\u7ea7</li> </ul> <p>\u72b9\u8bb0\u5f97\u5f53\u65f6\u82b1\u4e86\u4e00\u6574\u4e2a\u4e0b\u5348\u9ad8\u5f3a\u5ea6\u8c03\u8bd5\uff0c\u773c\u775b\u90fd\u82b1\u4e86\u624d\u8c03\u51fa\u6765\uff1b\u4e0b\u697c\u5403\u996d\u65f6\u5728\u7389\u6e56\u5927\u5385\u770b\u5230\u4e86\u540c\u6837\u9762\u5bf9\u4e00\u5806\u7535\u963b\u4e00\u7b79\u83ab\u5c55\u7684\u540c\u5b66\uff0c\u7a81\u7136\u5f88\u65e0\u529b\u7684\u7b11\u4e86\u8d77\u6765...\u8fd9\u79cd\u611f\u89c9\u76f4\u5230\u591a\u5e74\u4ee5\u540e\u9762\u5bf9\u7535\u8d5b\u624d\u88ab\u518d\u6b21\u56de\u5473\u8d77</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/isee_intro/#_3", "title": "\u8bfe\u7a0b\u8bbe\u8ba1\u62a5\u544a", "text": "", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/semiconductorfundamentals/", "title": "\u534a\u5bfc\u4f53\u7269\u7406", "text": "<p> \u7ea6 186 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4 1 \u5206\u949f</p> <p>Instructor\uff1a\u7a0b\u7136</p> <p>Semaster\uff1a\u5927\u4e8c\u6625\u590f</p> <p>\u8bfe\u7a0b\u7c7b\u522b\uff1a\u4e13\u4e1a\u5fc5\u4fee</p> <p>\u63a8\u8350\u6307\u6570\uff1a</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/semiconductorfundamentals/#_1", "title": "\u8bfe\u7a0b\u603b\u7ed3", "text": "<p>\u5206\u6570\u6784\u6210\uff1a20%\u671f\u4e2d\u8003+30%\u671f\u672b\u8003\uff08\u5206\u522b\u5728\u6625\u516b\u5468\u3001\u590f\u516b\u5468\u968f\u5802\u8fdb\u884c\uff09</p> <p>\u524d\u534a\u5b66\u671f\u4e3b\u8981\u6d89\u53ca\u7269\u7406\u90e8\u5206\u7684\u77e5\u8bc6\uff08\u4ece\u6676\u683c\u3001\u884d\u5c04\u3001\u57fa\u7840\u91cf\u5b50\u529b\u5b66\u5230\u534a\u5bfc\u4f53\u63ba\u6742\uff0c\u6d89\u53ca\u5e7f\u4f46\u4e0d\u6df1\uff0c\u6709\u5927\u96fe\u57fa\u7840\u5c31\u5e94\u8be5\u95ee\u9898\u4e0d\u5927\uff09</p> <p>\u540e\u534a\u5b66\u671f\u4e3b\u8981\u6d89\u53ca\u534a\u5bfc\u4f53\u5668\u4ef6\u90e8\u5206\u7684\u77e5\u8bc6\uff08\u4ecePN\u7ed3\u3001\u4e8c\u6781\u7ba1\u5230\u4e09\u6781\u7ba1\u3001\u573a\u6548\u5e94\u7ba1\uff09\uff0c\u662f\u671f\u672b\u8003\u8bd5\u7684\u91cd\u70b9\u3002</p> <p>\u5c5e\u4e8e\u56fd\u9645\u5316\u8bfe\u7a0b\uff0c\u5168\u82f1\u6587\uff0c\u4f46\u662f\u8001\u5e08\u7684\u53e3\u8bed\u5f88\u597d\uff0c\u8bed\u901f\u4e5f\u4e0d\u662f\u5f88\u5feb\uff0c\u6211\u611f\u89c9\u667a\u4e911.5\u500d\u901f\u4e5f\u4e0d\u592a\u6709\u95ee\u9898</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/semiconductorfundamentals/#_2", "title": "\u5f00\u5377\u8d44\u6599", "text": "<p>CC98\u7248</p> <p></p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/signal%26system/", "title": "\u4fe1\u53f7\u4e0e\u7cfb\u7edf", "text": "<p> \u7ea6 526 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4 2 \u5206\u949f</p> <p>Instructor\uff1a\u90d1\u658c\u3001\u8d75\u7eaa\u4f1f</p> <p>Semaster\uff1a\u5927\u4e8c\u6625\u590f</p> <p>\u8bfe\u7a0b\u7c7b\u522b\uff1a\u4e13\u4e1a\u5fc5\u4fee</p> <p>\u63a8\u8350\u6307\u6570\uff1a</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/signal%26system/#_1", "title": "\u8bfe\u7a0b\u603b\u7ed3", "text": "", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/signal%26system/#_2", "title": "\u5173\u4e8e\u8bfe\u7a0b", "text": "<p>\u4fe1\u53f7\u4e0e\u7cfb\u7edf\u4e2d\u6587\u73ed</p> <p>\u5206\u6570\u6784\u6210\uff1a\u5e73\u65f6\uff08\u4f5c\u4e1a+Matlab+\u8bfe\u5802\u8868\u73b0\uff0935% + \u8bfe\u7a0b\u8bbe\u8ba135% + \u95ed\u5377\u8003\u8bd530% </p> <p>\u53d1\u73b0\u5176\u5b9e\u8bfe\u7a0b\u8bbe\u8ba1\u5360\u6bd4\u6bd4\u8003\u8bd5\u8fd8\u5927\uff0c\u800c\u4e14\u8bfe\u7a0b\u8bbe\u8ba1\u7684\u8981\u6c42\u6bd4\u8f83\u4eba\u6027\u5316\uff0cddl\u5728\u8003\u8bd5\u4e4b\u524d\uff0c\u4e5f\u5c31\u662f\u671f\u672b\u5468\u6709\u5927\u628a\u7684\u65f6\u95f4\u53ef\u4ee5\u62ff\u6765\u6413\u8bfe\u7a0b\u8bbe\u8ba1+\u5199\u62a5\u544a</p> <p>\u8bfe\u7a0b\u5e73\u65f6\u7684\u8981\u6c42\u6bd4\u8f83\u5c11\uff0c\u4f5c\u4e3a\u4e00\u95e8\u56db\u5b66\u5206\u7684\u4e13\u4e1a\u8bfe\u76f8\u5f53\u53cb\u597d\uff0c\u552f\u4e00\u7684\u69fd\u70b9\u5c31\u662f\u4e00\u6b21\u5e03\u7f6e\u4e00\u7ae0\u7684\u4f5c\u4e1a\uff08\u8179\u6cfb\u5f0f\u5e03\u7f6e\uff0c\u4e00\u6b21\u4f5c\u4e1a\u80fd\u505a\u597d\u4e45\uff09\uff1b\u671f\u672b\u8003\u4e5f\u4e0d\u662f\u5f88\u4e3a\u96be\u4eba\uff0c\u5e73\u5747\u4e00\u4e2a\u5c0f\u65f6\u51fa\u5934\u5c31\u80fd\u505a\u5b8c\u4e00\u4efd\u5377\u5b50\uff0c\u6211\u76f4\u63a5\u8003\u8bd5\u524d\u4e00\u5929\u75af\u72c2\u62df\u54084\u4efd\u5386\u5e74\u5377\uff0c\u611f\u89c9\u9887\u6709\u6210\u6548</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/signal%26system/#_3", "title": "\u5173\u4e8e\u8001\u5e08", "text": "<p>\u90fd\u8bf4\u9694\u58c1\u73edhhj\u8001\u5e08\u975e\u5e38\u597d\uff0c\u6211\u504f\u8981\u6765\u5439\u4e00\u5439\u6211\u4eec\u90d1\u658c\u8001\u5e08</p> <p>\u8001\u5e08\u6e29\u6587\u5c14\u96c5\uff0c\u8bb2\u8bfe\u65f6\u7ecf\u5e38\u7b11\u54aa\u54aa\u7684\uff0c\u8bb2\u8bfe\u6c34\u5e73\u9ad8\uff0c\u6709\u91cd\u70b9\u3001\u8fdb\u5ea6\u9002\u4e2d\uff08\u636e\u8bf4\u9694\u58c1\u73edhhj\u8001\u5e08\u8bb2\u8bfe\u867d\u7136\u7ec6\u4f46\u662f\u8fdb\u5ea6\u6bd4\u8f83\u6162\uff09\uff1b</p> <p>\u6211\u89c9\u5f97\u90d1\u8001\u5e08\u73ed\u975e\u5e38\u597d\u7684\u4e00\u70b9\u662f\u7406\u8bba\u8bfe\u548c\u5b9e\u9a8c\u8bfe\u7684\u5206\u79bb\uff1a\u7406\u8bba\u90e8\u5206\u7531\u90d1\u8001\u5e08\u4e0a\uff0c\u5b9e\u9a8c\u90e8\u5206\u7531\u8d75\u8001\u5e08\u4e0a\uff1b\u7406\u8bba\u90e8\u5206\u53ef\u4ee5\u4e13\u6ce8\u4e8e\u8bfe\u5185\u7684\u77e5\u8bc6\uff08\u9762\u5411\u8003\u8bd5\uff09\uff0c\u800c\u5b9e\u9a8c\u90e8\u5206\u66f4\u5f3a\u8c03\u81ea\u5df1\u63a2\u7d22\u7422\u78e8MATLAB\uff0c\u4e2d\u95f4\u6709\u4e00\u4e2a\u5c0f\u7684\u5c55\u793a\uff0c\u6700\u540e\u8fd8\u6709\u4e00\u4e2a\u5927\u7684\u8bfe\u7a0b\u8bbe\u8ba1\u3002\u8d75\u8001\u5e08\u4eba\u4e5f\u975e\u5e38\u597d\uff0c\u975e\u5e38\u9f13\u52b1\u6211\u4eec\u81ea\u5df1\u63a2\u7d22\u548c\u4e0a\u53f0\u5c55\u793a\uff0c\u5373\u4f7f\u5c55\u793a\u7684\u6548\u679c\u4e0d\u662f\u5f88\u597d\u4e5f\u4f1a\u7ed9\u6211\u4eec\u5f88\u9ad8\u7684\u5206\u6570\u3002</p> <p>\u4e24\u4f4d\u8001\u5e08\u7ed9\u5206\u90fd\u5f88\u597d\uff0c\u51fa\u5206\u4e4b\u524d\u6211\u4e00\u76f4\u7d27\u5f20\u7d27\u5f20\u7d27\u5f20\u7d27\u5f20\u7d27\u5f20\uff0c\u56e0\u4e3a\u4e0d\u662f\u5f88\u6709\u5e95\uff0c\u7ed3\u679c\u51fa\u5206\u76f4\u63a5\u7ed9\u6211\u4e00\u4e2a\u5927\u60ca\u559c</p>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/isee/signal%26system/#_4", "title": "\u8bfe\u7a0b\u8d44\u6599", "text": "<ul> <li>\u8bfe\u7a0b\u8bbe\u8ba1\u62a5\u544a</li> </ul> <ul> <li>\u8865\u5929\u8d44\u6599 \uff08\u4e3b\u8981\u662f\u590d\u4e60\u8bfe\u7684\u5185\u5bb9\u4ee5\u53ca\u6211\u4e2a\u4eba\u4e0d\u592a\u719f\u7ec3\u7684\u5185\u5bb9\uff0c\u4e0d\u5168\uff09 </li> </ul>", "tags": ["\u7b14\u8bb0", "isee"]}, {"location": "notes/robot/robotexp/", "title": "\u673a\u5668\u4eba\u57fa\u7840\u5b9e\u8df5", "text": "<p> \u7ea6 0 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4\u4e0d\u5230 1 \u5206\u949f</p>"}, {"location": "notes/robot/robotintro/", "title": "\u673a\u5668\u4eba\u5bfc\u8bba", "text": "<p> \u7ea6 156 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4 1 \u5206\u949f</p> <p>Instructor\uff1a\u738b\u9149\u3001\u6731\u79cb\u56fd\u3001\u5434\u4fca\u3001\u738b\u8d8a</p> <p>Semaster\uff1a\u5927\u4e8c\u6625\u590f</p> <p>\u8bfe\u7a0b\u7c7b\u522b\uff1a\u8de8\u4e13\u4e1a\uff08\u81ea\u63a7\u4e13\u4e1a\u8bfe\uff09</p> <p>\u63a8\u8350\u6307\u6570\uff1a</p>", "tags": ["\u7b14\u8bb0", "\u8de8\u4e13\u4e1a"]}, {"location": "notes/robot/robotintro/#_1", "title": "\u8bfe\u7a0b\u6982\u8ff0", "text": "<p>\u5206\u6570\u6784\u6210\uff1a\u5e73\u65f6\uff08\u4f5c\u4e1a+\u70b9\u540d\uff0910% + IDC\u5927\u4f5c\u4e1a30% + \u95ed\u5377\u8003\u8bd560%</p> <p>\u8bfe\u7a0b\u5e73\u65f6\u6bd4\u8f83\u6c34\uff0c\u4ecb\u7ecd\u6027\u5730\u6db5\u76d6\u4e86\u4ece\u673a\u68b0\u5230\u5d4c\u5165\u5f0f\u5230\u7b97\u6cd5\u7684\u673a\u5668\u4eba\u51e0\u5927\u9886\u57df\uff0c\u671f\u672b\u8003\u5360\u6bd4\u5927\u8981\u597d\u597d\u51c6\u5907\uff1b\u5927\u4f5c\u4e1a\u4e00\u822c\u662f\u8fdb\u884c\u524d\u51e0\u5e74IDCRobocon\u7684\u9898\u76ee\u8bbe\u8ba1\uff0c\u4fa7\u91cd\u4e8e\u6bd4\u8d5b\u7b56\u7565\u548c\u673a\u5668\u4eba\u673a\u68b0\u7ed3\u6784\u7684\u8bbe\u8ba1\uff08\u8981\u753b\u51fasw\u6a21\u578b\uff09</p>", "tags": ["\u7b14\u8bb0", "\u8de8\u4e13\u4e1a"]}, {"location": "notes/robot/robotintro/#_2", "title": "\u8bfe\u7a0b\u8d44\u6599", "text": "<ul> <li>\u5927\u4f5c\u4e1a\u62a5\u544a</li> </ul> <ul> <li>\u671f\u672b\u590d\u4e60\u63d0\u7eb2</li> </ul>", "tags": ["\u7b14\u8bb0", "\u8de8\u4e13\u4e1a"]}, {"location": "projects/projects/", "title": "\u76ee\u5f55", "text": "<p> \u7ea6 85 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4\u4e0d\u5230 1 \u5206\u949f</p> <p>\u672c\u680f\u8bb0\u5f55\u4e0a\u5927\u5b66\u4ee5\u6765\u53c2\u4e0e\u7684\u5927\u5927\u5c0f\u5c0f\u7684\u9879\u76ee\u4e0e\u5b9e\u8df5\uff08\u4e0d\u5305\u542b\u8bfe\u7a0b\u5927\u4f5c\u4e1a\uff09</p> <p></p> <ul> <li>\u6d59\u6c5f\u7701\u201c\u4e2d\u63a7\u676f\u201d\u673a\u5668\u4eba\u7ade\u8d5b</li> <li> <p>\u673a\u5668\u4eba\u57fa\u7840\u5b9e\u8df5\uff08\u201c\u73ab\u7470\u6838\u201d\uff09</p> </li> <li> <p>\u6d59\u6c5f\u5927\u5b66\u667a\u80fd\u8f66\u7ade\u8d5b\u201c\u667a\u6167\u533b\u7597\u201d\u8d5b\u9053</p> </li> <li> <p>\"mearm\"\u673a\u68b0\u81c2\u5f00\u53d1</p> </li> <li> <p>\u6d59\u6c5f\u7701\u5927\u5b66\u751f\u7535\u5b50\u8bbe\u8ba1\u7ade\u8d5b</p> </li> </ul>"}, {"location": "thoughts/", "title": "Thoughts", "text": "<p> \u7ea6 18 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4\u4e0d\u5230 1 \u5206\u949f</p>", "tags": ["thoughts"]}, {"location": "thoughts/#_1", "title": "\u672c\u680f\u76ee\u8bb0\u5f55\u4e00\u4e9b\u968f\u65f6\u968f\u5730\u7684\u5927\u5c0f\u6709\u611f\u800c\u53d1", "text": "", "tags": ["thoughts"]}, {"location": "thoughts/history/", "title": "\u5c0f\u7a9d\u7684\u65bd\u5de5\u8bb0\u5f55", "text": "<p> \u7ea6 266 \u4e2a\u5b57</p> <p>/  \u9884\u8ba1\u9605\u8bfb\u65f6\u95f4 1 \u5206\u949f</p> <p>\u6301\u7eed\u66f4\u65b0\u4e2d...</p> <p>\u9646\u9646\u7eed\u7eed\u5f00\u53d1\u5c0f\u7a9d\u4e5f\u6709\u597d\u51e0\u4e2a\u6708\u4e86\uff0c\u89c9\u5f97\u975e\u5e38\u6709\u5fc5\u8981\u5f00\u4e00\u4e2a\u7248\u9762\u8bb0\u5f55\u5c0f\u7a9d\u4e00\u8def\u8d70\u6765\u7684\u70b9\u70b9\u6ef4\u6ef4\uff0c\u9042\u5199\u65bd\u5de5\u8bb0\u5f55~</p> <p>\u5f88\u53e4\u65e9\u7684\u7248\u672c\u5f53\u65f6\u90fd\u6ca1\u6709\u622a\u56fe\u4fdd\u5b58\uff0c\u662f\u540e\u6765\u7528git\u8fd8\u539f\u5386\u53f2\u7248\u672c\u540e\u91cd\u65b0\u6784\u5efa\u7684</p> 2026.06.14 v3.0 \u00b7 \u52a8\u6001\u58c1\u7eb8 <p>\u9996\u9875\u6413\u4e86\u4e24\u4e2a\u6bd4\u8f83\u6ee1\u610f\u7684\u52a8\u6001\u52a8\u753b</p> <p>\u6ce8\u610f\u767d\u663c\u6a21\u5f0f\u6a31\u82b1\u6811\u548c\u6a31\u82b1\u82b1\u74e3\u662f\u4f1a\u52a8\u7684\uff01</p> 2026.06.09 v2.0 \u00b7 \u9996\u9875\u91cd\u6784 <p>\u9996\u9875\u7528html\u52a0\u5165\u4e86\u8d1f\u4e00\u5c42\uff08\u8fd9\u4e00\u6b65\u7528ds\u641e\u4e86\u597d\u4e45\u6ca1\u641e\u5b9a\uff0c\u540e\u6765\u7528codex\u4e00\u4e0b\u5c31\u89e3\u51b3\u4e86...\uff09</p> <p>\u767d\u663c\u6a21\u5f0f\u7684\u56fe\u7247\u662f\u7528gpt\u751f\u6210\u7684:\uff09</p> 2026.04.24 v1.1 <p>\u52a0\u5165\u4e86\u4e24\u5f20\u9759\u6001\u56fe\u7247\u4f5c\u4e3a\u9996\u9875\u7684\u80cc\u666f</p> 2026.04.20 v1.0 \u00b7 \u5c0f\u7a9d\u843d\u6210 <p>\u5076\u7136\u770b\u5230MkDocs\uff0c\u679c\u65ad\u5c1d\u8bd5\uff0c\u6548\u679c\u60ca\u8273...\u5f53\u65f6\u7684\u9996\u9875\u8fd8\u662f\u7528\u7eafmarkdown\u624b\u6413\u7684\uff08</p> <p> \u00d7 </p> <p>\u5176\u5b9e\u6700\u5f00\u59cb\u7684\u5f00\u59cb\u6709\u4e00\u4e2a\u7528Jekyll\u642d\u5efa\u7684\u7248\u672c\uff0c\u4e0d\u8fc7\u7531\u4e8e\u4e0a\u624b\u6bd4\u8f83\u56f0\u96be\uff0c\u9042\u679c\u65ad\u8f6c\u6218MkDocs\u4e86</p>", "tags": ["\u4e00\u8def\u8d70\u6765"]}]}